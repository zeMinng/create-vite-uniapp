{
  "compilerOptions": {
    "target": "ES2023",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "@pkg": ["./package.json"],
      "@/*": ["./src/*"]
    },
  },
  "include": ["tsdown.config.ts", "src", "tests"],
  "exclude": ["node_modules", "dist"]
}