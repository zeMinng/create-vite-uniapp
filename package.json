{
  "name": "create-vite-uniapp",
  "version": "0.2.1",
  "description": "A fast CLI for scaffolding production-grade UniApp projects.",
  "type": "module",
  "bin": {
    "create-uniapp": "index.js"
  },
  "files": [
    "index.js",
    "templates",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc",
    "release": "bumpp",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeMinng/create-vite-uniapp.git"
  },
  "keywords": [
    "create-vite",
    "create-vite-uniapp",
    "create-uniapp",
    "uniapp",
    "vue",
    "vite",
    "cli",
    "scaffold",
    "boilerplate",
    "template"
  ],
  "author": "zeMinng",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/zeMinng/create-vite-uniapp/issues"
  },
  "homepage": "https://github.com/zeMinng/create-vite-uniapp#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@clack/prompts": "^1.7.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mri": "^1.2.0",
    "picocolors": "^1.1.1",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,js,json,md,yml,yaml}": "prettier --write"
  }
}
